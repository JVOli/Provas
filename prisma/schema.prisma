generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Race {
  id          String    @id @default(cuid())
  name        String
  date        DateTime
  dateEnd     DateTime?
  city        String
  state       String
  country     String    @default("Brasil")

  distances   String

  type        RaceType

  terrain     String?

  organizer   String?
  website     String?

  tier        RaceTier   @default(NONE)

  myDistance  String?

  notes       String?

  status      RaceStatus @default(NOT_REGISTERED)

  source      String?
  sourceUrl   String?

  elevation   String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([date])
  @@index([state])
  @@index([type])
  @@index([tier])
}

enum RaceType {
  CORRIDA
  TRAIL
  ULTRA
  TRIATHLON
  DUATHLON
  AQUATHLON
  BACKYARD
  REVEZAMENTO
  OCR
  OUTROS
}

enum RaceTier {
  NONE
  PRIMARY
  SECONDARY
  TERTIARY
  SUGGESTION
}

enum RaceStatus {
  NOT_REGISTERED
  REGISTERED
  COMPLETED
  DNS
  DNF
  CANCELLED
}
